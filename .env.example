# ==============================================================================
# 📥 WHATSAPP WEB PROTOCOL DEEP RECONNAISSANCE ENGINE - ENVIRONMENT TEMPLATE
# ==============================================================================

# Çalışma Modu (development, production, testing)
ENVIRONMENT=development

# Siber Güvenlik Log Seviyesi (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Çıktı ve Raporlama Konfigürasyonları
OUTPUT_FORMAT=markdown
DEFAULT_REPORT_PATH=reports/analysis-report.md

# Ofansif Simülasyon Ayarları
DEFAULT_FUZZ_INDEX=0
ENABLE_REPLAY_SIMULATION=true